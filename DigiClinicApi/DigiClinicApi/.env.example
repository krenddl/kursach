# These variables are for hosting panels like Render/Railway.
# Locally the API still uses appsettings.json and launchSettings.json.

ASPNETCORE_ENVIRONMENT=Production
PORT=8080

ConnectionStrings__DefaultConnection=Host=your-postgres-host;Port=5432;Database=digiclinic_db;Username=postgres;Password=change-me;SSL Mode=Require;Trust Server Certificate=true

Jwt__Key=change-this-to-a-long-random-secret-at-least-32-characters
Jwt__Issuer=DigiClinic.Api
Jwt__Audience=DigiClinic.Client
Jwt__ExpiresInMinutes=120

Frontend__AllowedOrigins__0=https://your-frontend.vercel.app

Telegram__Enabled=false
Telegram__BotToken=123456789:replace-with-your-telegram-bot-token
Telegram__PollingTimeoutSeconds=25
