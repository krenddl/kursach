@page "/admin/movies/create"
@using BlazorPractice1.ApiRequests
@using BlazorPractice1.ApiRequests.Model
@using BlazorPractice1.ApiRequests.Services
@inject ApiRequest ApiRequest
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="form-shell">
    <div class="card">
        <h2 class="form-title">Create Movie</h2>
        <p class="form-subtitle">Добавление нового фильма</p>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-error">@errorMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(succesMessage))
        {
            <div class="alert alert-success">@succesMessage</div>
        }

        <div class="form-group">
            <label class="form-label">Название</label>
            <input class="form-control" @bind="createMovie.Name" />
        </div>

        <div class="form-group">
            <label class="form-label">Описание</label>
            <textarea class="form-textarea" @bind="createMovie.Description"></textarea>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label">Жанр</label>
                <select class="form-select" @bind="createMovie.id_Genre">
                    @foreach (var genre in genres)
                    {
                        <option value="@genre.id_Genre">@genre.name</option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Рейтинг</label>
                <input class="form-control" type="number" step="0.1" @bind="createMovie.Rating" />
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">Дата</label>
            <input class="form-control" type="date" @bind="createMovie.Date" />
        </div>

        <div class="form-group">
            <label class="form-label">Постер</label>
            <InputFile OnChange="HandleFileSelected" />
        </div>

        <div class="form-actions">
            <button class="btn btn-primary" @onclick="CreateMovieAsync">Создать</button>
            <button class="btn btn-secondary" @onclick='() => Navigation.NavigateTo("/movies")'>Назад</button>
        </div>
    </div>
</div>

@code {
    private CreateMovieRequest createMovie = new CreateMovieRequest();
    private List<GenreResponse> genres = new List<GenreResponse>();
    private IBrowserFile? selectedFile;
    private string? errorMessage;
    private string? succesMessage;

    protected override async Task OnInitializedAsync()
    {
        await AuthService.LoadSessionAsync();
        await LoadGenres();
    }

    private async Task LoadGenres()
    {
        if (string.IsNullOrWhiteSpace(AuthService.Token))
        {
            errorMessage = "Токен не найден";
            return;
        }

        var result = await ApiRequest.GetAllGenres(AuthService.Token);

        if (result == null || !result.status || result.genres == null)
        {
            errorMessage = "Не удалось загрузить жанры";
            return;
        }

        genres = result.genres;

        if (genres.Count > 0)
        {
            createMovie.id_Genre = genres[0].id_Genre;
        }
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
    }

    private async Task CreateMovieAsync()
    {
        errorMessage = null;
        succesMessage = null;

        if (string.IsNullOrWhiteSpace(AuthService.Token))
        {
            errorMessage = "Токен не найден";
            return;
        }

        if (selectedFile != null)
        {
            var uploadResult = await ApiRequest.UploadMovieImageAsync(selectedFile, AuthService.Token);

            if (uploadResult == null || !uploadResult.status || string.IsNullOrWhiteSpace(uploadResult.img))
            {
                errorMessage = "Ошибка загрузки изображения";
                return;
            }

            createMovie.img = uploadResult.img;
        }

        var result = await ApiRequest.CreateMovieAsyncResponse(createMovie, AuthService.Token);

        if (result == null || !result.status)
        {
            errorMessage = "Ошибка создания фильма";
            return;
        }

        succesMessage = "Фильм создан";
        createMovie = new CreateMovieRequest();
        selectedFile = null;
    }
}